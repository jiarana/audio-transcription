# OpenAI API key (required)
OPENAI_API_KEY=sk-your-api-key-here

# JWT secret for authentication (required)
JWT_SECRET=change-this-to-a-random-secret

# Users with bcrypt-hashed passwords (required)
# Format: user1:bcrypt_hash,user2:bcrypt_hash
# Generate a hash: python -c "import bcrypt; print(bcrypt.hashpw(b'mypassword', bcrypt.gensalt()).decode())"
USERS=admin:$2b$12$example_bcrypt_hash_here

# CORS allowed origins (optional, default: localhost)
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# Max upload file size in MB (optional, default: 100)
MAX_FILE_SIZE_MB=100

# FFmpeg path (optional, falls back to system PATH)
# FFMPEG_PATH=/usr/local/bin
